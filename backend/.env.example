# ════════════════════════════════════════════════════════════════
# Sahayak — BlueCollar AI v2  |  Environment Configuration
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys
# ALL keys below are OPTIONAL — the app works without them
# with rule-based fallbacks. Add keys to unlock full AI power.

# ── LLM ──────────────────────────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=

# Get free key at: https://aistudio.google.com
GEMINI_API_KEY=

# ── Database ──────────────────────────────────────────────────────
# Default: SQLite (no setup needed)
# For production: postgresql+asyncpg://user:password@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./sahayak.db

# ── Cache ─────────────────────────────────────────────────────────
# Optional: Redis for rate limiting and caching
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────
# Change this in production!
JWT_SECRET=sahayak-super-secret-jwt-key-change-in-production
JWT_EXPIRE_MINUTES=1440

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── App Config ────────────────────────────────────────────────────
APP_NAME=Sahayak
APP_VERSION=2.0.0
DEBUG=true
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000

# ── Channels (optional) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
